{
  "name": "project-controls",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "tokens:build": "node scripts/generate-tokens-css.mjs",
    "dev": "npm run tokens:build && next dev --webpack",
    "prebuild": "npm run tokens:build",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/**/*.test.mjs",
    "guard:no-direct-upload": "node scripts/check-no-direct-upload.mjs",
    "supabase:start": "npx supabase start",
    "supabase:reset": "npx supabase db reset",
    "supabase:push": "npx supabase db push",
    "supabase:types": "npx supabase gen types typescript --local > src/types/database.types.ts",
    "storage:rename-yymmdd": "node --env-file=.env.local scripts/rename-attendance-storage-yymmdd.mjs",
    "storage:rename-field-installation-yymmdd": "node --env-file=.env.local scripts/rename-field-installation-storage-yymmdd.mjs",
    "sync:attendance": "node --env-file=.env.local scripts/run-attendance-sync.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.95.3",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "exceljs": "^4.4.0",
    "lucide-react": "^0.564.0",
    "next": "16.1.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.4.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "adm-zip": "^0.5.16",
    "autoprefixer": "^10.4.24",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "postcss": "^8.5.6",
    "shadcn": "^3.8.4",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
